<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"> <!-- Ensure this matches your namespace -->

    <application
        android:allowBackup="true"
        android:label="PaySay"
        android:theme="@style/Theme.Payment">

        <!-- THE ACTIVITY MUST BE INSIDE HERE -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service 
            android:name=".NotificationService"
            android:label="PaySay Listener"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

    </application>

    <queries>
        <!-- Wallets -->
        <package android:name="com.f1soft.esewa" />
        <package android:name="com.khalti" />
        <package android:name="com.swifttechnology.imepay" />
        <package android:name="com.swifttechnology.imepaymerchant" />
        <package android:name="com.prabhu.prabhupay" />
        <package android:name="com.f1soft.fonepay.merchant" />
        <package android:name="com.f1soft.fonepay.user" />

        <!-- Class A Banks -->
        <package android:name="com.f1soft.rastriyabanijyamobilebanking" />
        <package android:name="com.f1soft.nepalmobilebanking" />
        <package android:name="com.f1soft.adblmobilebanking" />
        <package android:name="com.f1soft.nicasiamobilebanking" /> 
        <package android:name="com.f1soft.nabilbank" />   
        <package android:name="com.f1soft.globalime" />   
        <package android:name="com.f1soft.nimb" />        
        <package android:name="com.f1soft.prabhubank" />  
        <package android:name="com.f1soft.siddharthamb" /> 
        <package android:name="com.f1soft.sanima" />      
        <package android:name="com.f1soft.citizencol" />  
        <package android:name="com.f1soft.kumari" />
        <package android:name="com.f1soft.primebank" />
        <package android:name="com.f1soft.nepalsbibank" />
        <package android:name="com.f1soft.standardchartered" />
        <package android:name="com.f1soft.himalayan" />   
        <package android:name="com.f1soft.machhapuchhre" />
        <package android:name="com.f1soft.sunrise" />     
        <package android:name="com.f1soft.everest" />     

